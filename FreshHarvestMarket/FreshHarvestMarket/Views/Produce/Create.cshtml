@*This view allows Admin to add new produce to database*@

@model FreshHarvestMarket.Models.Produce

@{
	ViewData["Title"] = "Add New Produce";
}

<h2>Add New Produce</h2>

<form asp-action="Create" method="post">

	<div asp-validation-summary="All" class="text-danger mb-3"></div>

	<div class="mb-3">
		<label asp-for="ProduceName">Produce Name</label>
		<input asp-for="ProduceName" class="form-control"/>
		<span asp-validation-for="ProduceName" class="text-danger"></span>

	</div>

	<div class="mb-3">
		<label asp-for="ProduceDescription">Produce Description</label>
		<textarea asp-for="ProduceDescription" class="form-control"></textarea>
		<span asp-validation-for="ProduceDescription" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="UnitPrice">Unit Price</label>
		<input asp-for="UnitPrice" class="form-control" type="number" step="0.01" placeholder="0.00" />
		<span asp-validation-for="UnitPrice" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="ProduceCategory">Produce Category</label>
		<input asp-for="ProduceCategory" class="form-control" />
		<span asp-validation-for="ProduceCategory" class="text-danger"></span>
	</div>

	<div class="mb-3">
		<label asp-for="InventoryTotal">Inventory Total</label>
		<input asp-for="InventoryTotal" class="form-control" type="number" placeholder="0" />
		<span asp-validation-for="InventoryTotal" class="text-danger"></span>

	</div>

	<div class="mb-3">
		<label asp-for="ImageUrl">Image URL</label>
		<input asp-for="ImageUrl" class="form-control" placeholder="default.jpg" />

		

	</div>

	<button type="submit" class="btn btn-success">
		Add Produce
	</button>

	<a asp-action="ManageProduce" class="btn btn-secondary">
		Cancel
	</a>
</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}