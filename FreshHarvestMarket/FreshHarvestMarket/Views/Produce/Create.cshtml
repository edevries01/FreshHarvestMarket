@*This view allows Admin to add new produce to database*@

@model FreshHarvestMarket.Models.Produce

@{
	ViewData["Title"] = "Add New Produce";
}

<h2>Add New Produce</h2>

<form asp-action="Create" method="post">

	<div class="mb-3">
		<label asp-for="ProduceName"></label>
		<input asp-for="ProduceName" class="form-control"/>
		<span asp-validation-for="ProduceName" class="text-danger"></span>

	</div>

	<div class="mb-3">
		<label asp-for="ProduceDescription"></label>
		<textarea asp-for="ProduceDescription" class="form-control"></textarea>

	</div>

	<div class="mb-3">
		<label asp-for="UnitPrice"></label>
		<input asp-for="UnitPrice" class="form-control" type="number" step="0.01"/>

	</div>

	<div class="mb-3">
		<label asp-for="ProduceCategory"></label>
		<input asp-for="ProduceCategory" class="form-control" />

	</div>

	<div class="mb-3">
		<label asp-for="InventoryTotal"></label>
		<input asp-for="InventoryTotal" class="form-control" />

	</div>

	<div class="mb-3">
		<label asp-for="ImageUrl"></label>
		<input asp-for="ImageUrl" class="form-control" placeholder="apple.jpg" />

		

	</div>

	<button type="submit" class="btn btn-success">
		Add Produce
	</button>

	<a asp-action="ManageProduce" class="btn btn-secondary">
		Cancel
	</a>
</form>