@*
 * Produce/ Favorites.cshtml
 * FreshHarvestMarket
 *
 * This Razor view displays a user's favorite produce items.
 * Users can view their saved favorites, navigate to item details,
 * or remove items from their favorites list.
 *
 * This page uses the FavoritesViewModel to render a list of
 * favorite produce items & handles conditional rendering when
 * no favorites exist.
 *@

@model FavoritesViewModel

@{
    ViewData["Title"] = "Your Favorites";

}

<div class="container">
    <h2 class="mb-4"><i class="bi bi-heart-fill text-danger"></i> My Favorite Produce</h2>

    @if (!Model.FavoriteItems.Any())
    {
        <div class="alert alert-info">
            You haven't added any favorites yet. <a asp-action="Index">Go shopping!</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model.FavoriteItems)
            {
                <div class="col-sm-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm produce-card">
                        <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl)
                                         ? Url.Content("~/images/default.jpg")
                                         : Url.Content("~/images/" + item.ImageUrl))"
                     class="card-img-top p-2"
                     style="height: 180px; object-fit: cover;"
                     alt="@item.ProduceName" />

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.ProduceName</h5>
                            <p class="text-muted">@item.UnitPrice.ToString("C")</p>

                            <div class="mt-auto">
                                <a asp-action="Details" 
                                asp-route-id="@item.ProduceId"
                                class="btn btn-outline-success w-100">
                                View Details
                            </a>

                                @*Delete Favorite*@
                                <form asp-action="DeleteFavorite" method="post">
                                    <input type="hidden" name="produceId" value="@item.ProduceId" />

                                    <button type="submit" 
                                        class="btn btn-danger w-100">
                                        Remove
                                    </button>
                                </form>
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
</div>