@*
 * Produce/ ManageProduce.cshtml
 * FreshHarvestMarket
 *
 * This Razor view provides an administrative interface for managing
 * all produce items in the system.
 *
 * Admin users can:
 * - View all produce items in a tabular format
 * - Add new produce items
 * - Edit or delete existing produce items
 * - Update inventory levels directly from the table
 *
 * This view uses a List<Produce> model to display & manage
 * produce data in a CRUD-style interface.
*@

@model List<FreshHarvestMarket.Models.Produce>

	<h2>Manage Produce</h2>

	<a asp-action="Create" class="btn btn-primary mb-3">Add New Produce</a>

<div class="table-responsive">
	<table class="table table-striped">
		<thead>
			<tr>
				<th>Name</th>
				<th>Category</th>
				<th>Price</th>
				<th>Inventory</th>
				<th>Actions</th>
			</tr>
		</thead>

		<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>@item.ProduceName</td>
				<td>@item.ProduceCategory</td>
				<td>@item.UnitPrice.ToString("C")</td>
				<td>
					<form asp-action="UpdateInventory"
					method="post"
					class="d-flex gap-2 align-items-center">

					<input type="hidden"
						name="produceId"
						value="@item.ProduceId"/>

						<!--New value input-->
						<input type="number"
							name="inventoryTotal"
							class="form-control form-control-sm"
							style="width: 80px;"
							value="@item.InventoryTotal"/>

							<!--Save button-->
							<button type="submit" class="btn btn-sm btn-primary">
								Save
							</button>
				</form>
				</td>

				<td>
					<a asp-action="Edit" asp-route-id="@item.ProduceId" class="btn btn-warning btn-sm">
						Edit
					</a>

					<form asp-action="Delete" asp-route-id="@item.ProduceId" method="post" style="display:inline;">
						<button class="btn btn-danger btn-sm" onclick="return confirm('Delete this item?');">
							Delete

						</button>

					</form>
				</td>
			</tr>
		}
		</tbody>

	</table>
</div>