
@model BrowseProduceViewModel

@{
	ViewData["Title"] = "Marketplace";

}

<div class="row">
	<div class="col-md-3">
		<h4 class="fw-bold mb-3 text-success">Categories</h4>


		<div class="list-group shadow-sm rounded">
			<a asp-action="Index" asp-route-category="All"
			   class="list-group-item list-group-item-action @(Model.SelectedCategory == "All" ? "active" : "")">
				All Produce
			</a>
			<!--Button for every category-->
			@foreach (string cat in Model.Categories)
			{
				<a asp-action="Index" asp-route-category="@cat" class="list-group-item list-group-item-action @(Model.SelectedCategory == cat ? "active" : "")">
					@cat
				</a>
			}

		</div>

	</div>

	<div class="col-md-9">
		<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="mb-4">Browsing: @Model.SelectedCategory</h2>


		
		</div>

		<div class="row">
			<!--Card for every item-->
			@foreach (var item in Model.ProduceItems)
			{
				<div class="col-sm-6 col-lg-4 mb-4">
					@{
						bool isFavorite = Model.FavoriteIds.Contains(item.ProduceId);
					}
					<!--Card container-->
					<div class="card h-100 shadow-sm produce-card">

						<!--Image container-->
						<div class="bg-white text-center border-bottom">
							<img src="@(string.IsNullOrEmpty(item.ImageUrl)
									? Url.Content("~/images/default.jpg")
									: Url.Content("~/images/" + item.ImageUrl))"
								class="card-img-top p-2"
								alt="@item.ProduceName"
								style="height: 180px; object-fit: cover;" />

						</div>

						<div class="card-body">
							<h5 class="card-title">@item.ProduceName</h5>
						@if (User.Identity.IsAuthenticated &&
												item.Discount != null &&
												item.Discount.DiscountAmount > 0)
							{
								var discounted = item.UnitPrice * (1 - item.Discount.DiscountAmount / 100.0m);

								<p class="card-text">
									<span class="text-muted text-decoration-line-through me-2">
										@item.UnitPrice.ToString("C")
									</span>

									<span class="text-success fw-bold">
										@discounted.ToString("C")
									</span>
								</p>

								<span class="badge bg-success mb-2">
									Save @item.Discount.DiscountAmount%
								</span>
							}
							else
							{
								<p class="card-text text-muted">
									@item.UnitPrice.ToString("C")
								</p>
							}

							@if (item.InventoryTotal == 0)
							{
								<p class="small text-danger">Out of Stock</p>
							}
							else if (item.InventoryTotal <= 5)
							{
								<p class="small text-warning">Only @item.InventoryTotal left!</p>
							}
							else
							{
								<p class="small text-success">In Stock: @item.InventoryTotal</p>
							}

							<!--Sends Item ID to Details page when clicked-->
							<a asp-action="Details" asp-route-id="@item.ProduceId" class="btn btn-outline-success w-100">View Details</a>

							@if (item.InventoryTotal > 0)
							{
								<a asp-controller="Cart"
								   asp-action="Add"
								   asp-route-id="@item.ProduceId"
								   asp-route-name="@item.ProduceName"
								   asp-route-image="@item.ImageUrl"
								   asp-route-price="@item.UnitPrice"
								   asp-route-maxQuantity="@item.InventoryTotal"
								   class="btn btn-primary w-100 mt-2">
									Add to Cart
								</a>
							}
							else
							{
								<button class="btn btn-secondary w-100 mt-2" disabled>
									Out of Stock
								</button>
							}

							<form asp-action="AddFavorite" method="post" class="mt-2 text-end">
								<input type="hidden" name="produceId" value="@item.ProduceId" />
								<button type="submit" class="btn border-0 bg-transparent p-0 shadow-none heart-btn">
									<i class="bi @(isFavorite ? "bi-heart-fill" : "bi-heart") fs-4 text-danger heart-icon"></i>
								</button>

							</form>
						
						</div>

					</div>

				</div>
			}

		</div>

	</div>
</div>