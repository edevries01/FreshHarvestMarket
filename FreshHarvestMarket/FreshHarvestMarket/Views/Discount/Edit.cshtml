@*Screen for adding/editing a discount*@
@model Discount

<h2 class="mb-3">
    @(ViewBag.Action == "Add" ? "Add a New Discount" : "Edit Discount")
</h2>

<form asp-action="Edit" method="post">

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <!-- PRODUCE -->
    <div class="mb-3">
        <label asp-for="ProduceId" class="form-label">Produce</label>
        <select asp-for="ProduceId" class="form-select">
            <option value="">-- Select a product --</option>
            @foreach (Produce p in ViewBag.Produce)
            {
                <option value="@p.ProduceId">@p.ProduceName</option>
            }
        </select>
        <span asp-validation-for="ProduceId" class="text-danger"></span>
    </div>

    <!-- DISCOUNT -->
    <div class="mb-3">
        <label asp-for="DiscountAmount" class="form-label">Discount (%)</label>
        <input asp-for="DiscountAmount" class="form-control" placeholder="Enter % (1–99)" />
        <span asp-validation-for="DiscountAmount" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="DiscountId" />

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-controller="Discount" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}