@*
 * _Layout.cshtml
 * FreshHarvestMarket
 *
 * This is the main shared layout for the application.
 * It defines the overall structure of all pages, including:
 * - Navigation bar with role-based menu options (User/Admin)
 * - Authentication-aware UI (Login, Logout, Register)
 * - Shopping cart and favorites navigation
 * - Admin management dropdown (Produce, Discounts)
 *
 * It also includes:
 * - Bootstrap & styling references
 * - Footer with contact information & weather component
 * - Script & section rendering for child views
 *
 * This layout is applied to all Razor views in the application.
 *@

@using Microsoft.AspNetCore.Identity
@using FreshHarvestMarket.Models;
@inject SignInManager<User> signInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FreshHarvestMarket</title>
    <link rel="icon" type="image/x-icon" href="~/images/freshharvestmarket.JPG">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FreshHarvestMarket.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3 navbar-fresh">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">FreshHarvestMarket</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About">About</a>
                        </li>

                        <!--Shop Produce link w/ dropdown link for Favorites-->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="produceDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Shop Produce
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="produceDropdown">
                                <li>
                                    <a class="dropdown-item" asp-controller="Produce" asp-action="Index">Browse All</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Produce" asp-action="Favorites">
                                    <i class="bi bi-heart-fill text-danger me-1"></i>My Favorites
                                    </a>

                                </li>

                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Order" asp-action="Index">Orders</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i> Cart
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (signInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">Admin<span class="caret"></span></a>
                                <!--Drop down list for admin stuff-->
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Produce" asp-action="ManageProduce">Manage Produce</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Discount" asp-action="Index">Manage Discounts</a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!--Nav items for login, from class examples-->
                        @if (signInManager.IsSignedIn(User))
                        {
                            // signed-in user - Log Out button and username
                            <li class="nav-item d-flex align-items-center gap-2">

                                <span class="navbar-text text-success fw-semibold">
                                    👋 Welcome, @User.Identity.Name!
                                </span>

                                <form method="post" asp-action="LogOut" asp-controller="Account" asp-area="">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        Log Out
                                    </button>
                                </form>

                            </li>
                        }
                        else
                        {
                            // anonymous user - Register link and Log In button
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Account" asp-action="Login">&nbsp;Log In</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-5 mb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container text-center">

            @await Component.InvokeAsync("Weather")

            <p class="mb-0">
                &copy; @DateTime.Now.Year - Fresh Harvest Market
            </p>

            <p class="mb-0">
                Supporting Local Farms • Fresh Food • Community First
            </p>

            <p class="mb-0 mt-2">
                Contact: support@freshharvestmarket.example
            </p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
