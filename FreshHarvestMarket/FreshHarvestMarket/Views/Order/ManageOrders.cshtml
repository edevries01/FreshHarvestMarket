@*
    This view is for the Fresh Harvest Market operator only
    It displays all the unfufilled orders, and let's the operator make updates
    Future: Lock behind admin role
    Future: Add link to browse all orders, even fufilled ones
*@
@model List<Order>
<div class="row">
    <div class="col">
        <h1>Manage Active Orders</h1>
    </div>
    <div class="col">
        <div class="col">
            <a class="btn btn-primary">See Archived</a>
        </div>
    </div>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Order Number</th>
            <th>Pickup Date</th>
            <th>Order Total</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (Order order in Model)
        {
            <tr>
                <td>@order.OrderId</td>
                <td>@order.PickupDate.ToString("MM/dd/yyyy")</td>
                <td>@order.OrderTotal.ToString("C")</td>
                @if (order.PickupDate < DateTime.Now.Date)
                {
                    <td class="text-warning">Overdue</td>
                }
                else if (order.PickupDate.AddDays(7).Date < DateTime.Now.AddDays(7).Date)
                {
                    <td>Upcoming</td>
                }
                else if (order.PickupDate.Date == DateTime.Now.Date)
                {
                    <td>Pick-Up Today</td>
                }
                else
                {
                    <td>-</td>
                }
                <td>
                    <a asp-controller="Order" asp-action="ViewOrder" asp-route-orderId="@order.OrderId" class="btn btn-primary">View Order</a>
                    <form asp-action="UpdateFufilled" method="post" asp-route-OrderId="@order.OrderId" class="d-inline">
                        <button type="submit" class="btn btn-primary">Fufilled</button>
                    </form>
                    <a asp-controller="Order" asp-action="ConfirmReject" asp-route-orderId="@order.OrderId" class="btn btn-primary">Reject</a>
                </td>
            </tr>
        }
    </tbody>
</table>