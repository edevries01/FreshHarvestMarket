@*This view lets the operator view a specific order in more detail*@
@model Order

<div class="justify-content-center">
    <div class="row">
        <div class="col">
            <h1>Order @Model.OrderId Details</h1>
        </div>
    </div>
    
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Order Info</th>
                <th>Value</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Pick-Up Date</td>
                <td>@Model.PickupDate.ToString("MM/dd/yyyy")</td>
            </tr>
            <tr>
                <td>Fufilled?</td>
                <td>@(Model.IsPickedUp ? "Yes" : "No")</td>
            </tr>
            <tr>
                <td>Order Placed</td>
                <td>@Model.OrderDate.ToString("MM/dd/yyyy")</td>
            </tr>
            <tr>
                <td>Order Total</td>
                <td>@Model.OrderTotal.ToString("C")</td>
            </tr>
            <tr>
                <td>Products in Order</td>
                <td>@Model.Items.Count</td>
            </tr>
            <tr>
                <td>Rejected?</td>
                <td>@(Model.Rejected ? "Yes" : "No")</td>
            </tr>
        </tbody>
    </table>

    <h1>Order Item Details</h1>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <td></td>
                <td>Product</td>
                <td>Quantity</td>
                <td>Price</td>
                <td>Total</td>
            </tr>
        </thead>
        <tbody>
            @foreach (OrderItem orderItem in Model.Items)
            {
                <tr>
                    <td>
                        <img src="~/images/@orderItem.Produce!.ImageUrl"
                             style="width:50px; height:50px; object-fit:cover;" />
                    </td>
                    <td>@orderItem.Produce!.ProduceName</td>
                    <td>@orderItem.Quantity</td>
                    <td>
                        @orderItem.Produce!.UnitPrice.ToString("C")
                    </td>
                    <td>
                        @{
                            decimal unitPrice = orderItem.Produce!.UnitPrice;
                            decimal lineTotal = orderItem.Quantity * unitPrice;
                        }
                        @lineTotal.ToString("C")
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Order" asp-action="ManageOrders" class="btn btn-primary">Manage Orders</a>
    <form asp-action="UpdateFufilled" method="post" asp-route-OrderId="@Model.OrderId" class="d-inline">
        <button type="submit" class="btn btn-primary">Fufilled</button>
    </form>
    <a asp-controller="Order" asp-action="UpdateRejected" asp-route-orderId="@Model.OrderId" class="btn btn-primary">Reject</a>
</div>
