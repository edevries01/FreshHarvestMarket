@*
 * Order/ Details.cshtml
 * FreshHarvestMarket
 *
 * This Razor view displays detailed information for a specific order.
 *
 * It includes:
 * - Order summary information (dates, total cost, status, & item count)
 * - A breakdown of all items within the order, including product images
 *   & quantities
 *
 * For authenticated admin users, the view also provides management actions:
 * - Mark order as fulfilled
 * - Reject order
 *
 * Access to administrative actions is restricted based on user role
 * & order status.
 *@

@model Order
@inject SignInManager<User> signInManager

<div class="justify-content-center">
    <div class="row">
        <div class="col">
            <h1>Order @Model.OrderId Details</h1>
        </div>
    </div>
    
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Order Info</th>
                <th>Value</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Pick-Up Date</td>
                <td>@Model.PickupDate.ToString("MM/dd/yyyy")</td>
            </tr>
            <tr>
                <td>Fulfilled?</td>
                <td>@(Model.IsPickedUp ? "Yes" : "No")</td>
            </tr>
            <tr>
                <td>Order Placed</td>
                <td>@Model.OrderDate.ToString("MM/dd/yyyy")</td>
            </tr>
            <tr>
                <td>Order Total</td>
                <td>@Model.OrderTotal.ToString("C")</td>
            </tr>
            <tr>
                <td>Products in Order</td>
                <td>@Model.Items.Count</td>
            </tr>
            <tr>
                <td>Rejected?</td>
                <td>@(Model.Rejected ? "Yes" : "No")</td>
            </tr>
        </tbody>
    </table>

    <h1>Order Item Details</h1>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <td></td>
                <td>Product</td>
                <td>Quantity</td>
            </tr>
        </thead>
        <tbody>
            @foreach (OrderItem orderItem in Model.Items)
            {
                <tr>
                    <td>
                        <img src="@(string.IsNullOrWhiteSpace(orderItem.Produce?.ImageUrl)
                                         ? Url.Content("~/images/default.jpg")
                                         : Url.Content("~/images/" + orderItem.Produce.ImageUrl))"
                         style="width:50px; height:50px; object-fit:cover;" />
                    </td>
                    <td>@orderItem.Produce!.ProduceName</td>
                    <td>@orderItem.Quantity</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-controller="Order" asp-action="Index" class="btn btn-primary">All Orders</a>
    
    @if (!Model.IsPickedUp && !Model.Rejected && signInManager.IsSignedIn(User) && User.IsInRole("Admin"))
    {
        <form asp-action="UpdateFulfilled" method="post" asp-route-OrderId="@Model.OrderId" class="d-inline">
            <button type="submit" class="btn btn-primary">Fulfilled</button>
        </form>
        <a asp-controller="Order" asp-action="ConfirmReject" asp-route-orderId="@Model.OrderId" class="btn btn-danger">Reject</a>
    }
</div>
