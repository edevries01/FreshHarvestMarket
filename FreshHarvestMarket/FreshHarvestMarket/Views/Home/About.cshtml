@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">

    <h1 class="text-center mb-5">About Fresh Harvest Market</h1>

    <!-- Section 1 -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h3>Our Community Focus</h3>
            <p>
                Fresh Harvest Market was created to connect our local community with fresh,
                locally grown produce. We partner with nearby farms to offer seasonal fruits,
                vegetables, and handmade goods like honey. Our goal is to make it easy for
                customers to browse what is available before visiting the market, helping both
                shoppers and farmers plan ahead.
            </p>
            <p>
                By reserving items online, customers can quickly pick up their selections while
                supporting local agriculture and small businesses.
            </p>
        </div>

        <div class="col-md-6 text-center">
            <img src="~/images/produce_field.jpg" class="img-fluid rounded shadow" alt="Local Farm">
        </div>
    </div>

    <!-- Section 2 -->
    <div class="row align-items-center">
        <div class="col-md-6 text-center">
            <img src="~/images/farmer_market_exchange.jpg" class="img-fluid rounded shadow" alt="Fresh Produce">
        </div>

        <div class="col-md-6">
            <h3>Simple, Transparent Shopping</h3>
            <p>
                Fresh Harvest Market is designed to provide a simple and transparent experience.
                Customers can browse as guests or create an account to receive member discounts,
                save favorites, and track their reservations. Instead of online payments, the site
                calculates a total amount owed at pickup, keeping the process flexible and secure.
            </p>
            <p>
                We also highlight where products come from, giving customers confidence in the
                quality and origin of the food they bring home.
            </p>
        </div>
    </div>

</div>