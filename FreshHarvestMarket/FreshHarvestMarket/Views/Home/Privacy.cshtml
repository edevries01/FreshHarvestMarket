@*
 * Home/Privacy.cshtml
 * FreshHarvestMarket
 *
 * This Razor view displays the application's privacy policy information.
 *
 * It provides users with details regarding:
 * - What personal data is collected
 * - How user information is used & protected
 * - Security & transparency practices
 * - Contact information for questions or concerns
 *
 * This is a static informational page & does not interact with
 * the database or application models.
 *@

@{
    ViewData["Title"] = "Privacy";
}

<div class="container mt-4">

    <h1 class="text-center mb-5">Privacy Policy</h1>

    <!-- Section 1 -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <h3>Your Information</h3>
            <p>
                Fresh Harvest Market collects only the information necessary to process
                your orders and improve your experience. This may include your name,
                contact details, and order history.
            </p>
            <p>
                We do not sell or share your personal information with third parties.
                Your data is used strictly for managing reservations and providing
                a smooth shopping experience.
            </p>
        </div>
    </div>

    <!-- Section 2 -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <h3>Security & Transparency</h3>
            <p>
                We take reasonable steps to protect your information and ensure that
                your data is handled securely. Orders are processed within the system,
                and payment is completed in person at pickup.
            </p>
            <p>
                Our goal is to provide a simple, transparent, and secure experience
                for all users.
            </p>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="row justify-content-center text-center mt-5">
        <div class="col-md-8">
            <h4>Contact</h4>
            <p>
                If you have questions about this policy, you may contact us at
                <strong>support@freshharvestmarket.example</strong>.
            </p>
            <p class="text-muted">
                This application is a student project and not a commercial service.
            </p>
        </div>
    </div>

</div>