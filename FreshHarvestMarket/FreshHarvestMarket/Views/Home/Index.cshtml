@*
 * Home/Index.cshtml
 * FreshHarvestMarket
 *
 * This Razor view serves as the application's homepage.
 *
 * It provides a marketing-style landing page that introduces users
 * to the Fresh Harvest Market platform & its mission.
 *
 * The page includes:
 * - A hero header introducing the application
 * - A Bootstrap image carousel highlighting local produce & farming
 * - Feature sections describing key functionality (browse, reserve, pickup)
 * - A call-to-action button linking to the produce marketplace
 *
 * This is a static informational view & does not interact with
 * application models or the database.
 *@

@{
    ViewData["Title"] = "Home Page";
}

<!-- Page Header -->
<div class="text-center mb-4">
    <h1 class="display-4">Fresh Harvest Market</h1>
    <p class="lead">Connecting you with fresh, locally grown products.</p>
</div>

<!-- Carousel -->
<div id="marketCarousel" class="carousel slide mb-5" data-bs-ride="carousel">
    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="~/images/multi_produce_display.jpg" class="d-block w-100" alt="Fresh Produce">
            <div class="carousel-caption d-none d-md-block">
                <h3>Fresh From Local Farms</h3>
                <p>Seasonal produce harvested at peak freshness.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/farmer_on_tractor.jpg" class="d-block w-100" alt="Support Local Farmers">
            <div class="carousel-caption d-none d-md-block">
                <h3>Support Your Community</h3>
                <p>Every purchase supports nearby growers.</p>
            </div>
        </div>

        <div class="carousel-item">
            <img src="~/images/bee_hives.jpg" class="d-block w-100" alt="Honey">
            <div class="carousel-caption d-none d-md-block">
                <h3>Natural & Local</h3>
                <p>Honey, fruits, and vegetables sourced locally.</p>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#marketCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#marketCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- Features Section -->
<div class="row text-center mb-4">
    <div class="col-md-4">
        <h4>Browse Local Products</h4>
        <p>Explore fruits, vegetables, honey, and more grown by nearby farms.</p>
    </div>

    <div class="col-md-4">
        <h4>Reserve Online</h4>
        <p>Select items and quantities to reserve — no online payment required.</p>
    </div>

    <div class="col-md-4">
        <h4>Pick Up at Market</h4>
        <p>Receive your total and pay when you arrive for a simple experience.</p>
    </div>
</div>

<!-- Button -->
<div class="text-center mb-5">
    <a class="btn btn-success btn-lg" asp-controller="Produce" asp-action="Index">
        View Available Produce
    </a>
</div>