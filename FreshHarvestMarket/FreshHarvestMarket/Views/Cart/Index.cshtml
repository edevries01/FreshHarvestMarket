@*
 * Cart/Index.cshtml
 * FreshHarvestMarket
 *
 * This Razor view displays the user's shopping cart & allows
 * management of selected produce items prior to checkout.
 *
 * Users can:
 * - View items currently in their cart
 * - Update item quantities
 * - Remove items from the cart
 * - View itemized pricing with optional discounts
 * - Proceed to checkout or continue shopping
 *
 * The view dynamically calculates totals & displays discounted pricing
 * for authenticated users when applicable.
 *
 * If the cart is empty, the user is prompted to begin shopping.
 *@

@model List<FreshHarvestMarket.Models.CartItem>

@{
    ViewData["Title"] = "Cart";
}

<h2>Your Cart</h2>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <h3>Your cart is empty 🛒</h3>
        <p>Start shopping fresh produce!</p>

        <a asp-controller="Produce" asp-action="Index"
           class="btn btn-success mt-3">
            Browse Produce
        </a>
    </div>
    return;
}

@if (TempData["CartError"] != null)
{
    <div class="alert alert-danger">
        @TempData["CartError"]
    </div>
}
<div class="table-responsive">
<table class="table">
    <thead>
        <tr>
            <th></th>
            <th>Item</th>
            <th>Price</th>
            <th>Qty</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl)
                                     ? Url.Content("~/images/default.jpg")
                                     : Url.Content("~/images/" + item.ImageUrl))"
                     style="width:60px;height:60px;object-fit:cover;" />
                </td>
                <td>@item.ProduceName</td>
                <td>
                    @if (User.Identity.IsAuthenticated && item.DiscountAmount.HasValue && item.DiscountAmount > 0)
                    {
                        <span class="text-muted text-decoration-line-through">
                            @item.Price.ToString("C")
                        </span>
                        <span class="text-success">
                            @item.DiscountedPrice.ToString("C")
                        </span>
                    }
                    else
                    {
                        @item.Price.ToString("C")
                    }
                </td>
                <td>
                    <form asp-action="Update" method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@item.ProduceId" />

                        <input type="number"
                               name="quantity"
                               value="@item.Quantity"
                               min="1"
                               class="form-control form-control-sm"
                               style="width:80px;" />

                        <button type="submit" class="btn btn-primary btn-sm">
                            Update
                        </button>
                    </form>
                </td>
            <td>
                @(
                                User.Identity.IsAuthenticated &&
                                item.DiscountAmount.HasValue &&
                                item.DiscountAmount > 0
                                ? (item.DiscountedPrice * item.Quantity).ToString("C")
                                : (item.Price * item.Quantity).ToString("C")
                                )
            </td>
                <td>
                    <a asp-action="Remove" asp-route-id="@item.ProduceId"
                       class="btn btn-danger btn-sm">Remove</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>

<h3>Total: @ViewBag.Total.ToString("C")</h3>

<a asp-controller="Checkout" asp-action="Index"
   class="btn btn-success">Checkout</a>

<a asp-controller="Produce" asp-action="Index" class="btn btn-outline-secondary">
    Keep Shopping
</a>